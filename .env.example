# Frontend
VITE_API_BASE_URL=
VITE_SUPABASE_URL=      # e.g. https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY= # Supabase anon/publishable key

# Backend
DEBUG=false
SUPABASE_URL=           # Same as VITE_SUPABASE_URL (e.g. https://xxx.supabase.co)

# Market Data + Fundamentals (Massive.com / Polygon.io — same API key)
MASSIVE_API_KEY=        # Get from https://massive.com (used for market data and fundamentals)

# SEC API (optional - for enhanced SEC filings access)
# Get from https://sec-api.io (free tier available). Falls back to SEC EDGAR RSS if not provided
SEC_API_KEY=